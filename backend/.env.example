# Copy this file to .env and fill in your values

# Neon Postgres connection string
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Groq API key (free at https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq model settings
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile
GROQ_MAX_RETRIES=3
GROQ_RETRY_BASE_DELAY=2
GROQ_MAX_CONCURRENCY=2

# Path to contract YAML file
# Defaults to backend/contracts/example_contracts.yaml when unset
CONTRACTS_YAML_PATH=contracts/example_contracts.yaml

# CORS origin for the React dashboard
CORS_ORIGIN=http://localhost:5173

# Simple in-memory per-IP rate limit for public trace endpoints
# Good for demo/single-process deployments; use Redis or an API gateway for distributed production limits
TRACE_RATE_LIMIT_MAX_REQUESTS=5
TRACE_RATE_LIMIT_WINDOW_SECONDS=60
